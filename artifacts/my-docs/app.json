{
  "expo": {
    "name": "My Docs by NM v2",
    "slug": "my-docs-v2",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "my-docs-v2",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080F"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "My Docs uses the camera to scan your documents and cards.",
        "NSPhotoLibraryUsageDescription": "My Docs saves scanned documents to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "My Docs needs to access your photo library."
      }
    },
    "android": {
      "package": "com.mydocsbynm.appv2",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "My Docs needs camera access to scan your documents and cards."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow My Docs to access your photos to replace document images.",
          "cameraPermission": "Allow My Docs to use the camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
